# Variables à renseigner sur le VPS qui héberge Ollama.
# Copiez ce fichier en `.env` (à côté de docker-compose.yml) et remplissez.

# Domaine pointé vers l'IP du VPS (enregistrement DNS A/AAAA).
# Caddy obtiendra automatiquement un certificat TLS Let's Encrypt pour ce nom.
OLLAMA_DOMAIN=ollama.veliora.fr

# Clé Bearer secrète attendue par le reverse-proxy.
# Générer avec : `openssl rand -base64 48 | tr -d /=+ | cut -c1-48`
# La même valeur doit être configurée côté app Veliora (variable OLLAMA_API_KEY).
OLLAMA_API_KEY=remplacez-par-une-cle-aleatoire-tres-longue
