# ═══════════════════════════════════════════════════════════════════════════════
# Veliora — Variables d'environnement
# Copiez ce fichier en `.env` à la racine du projet et renseignez les valeurs.
# Ne commitez jamais `.env` (clés secrètes).
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────────────────
# URL publique du site (vitrine + CRM + redirections Stripe)
APP_PUBLIC_URL=http://localhost:8000

# Google Maps / Geocoding (deux clés recommandées en production)
# GOOGLE_MAPS_API_KEY=          → clé navigateur : Maps JavaScript API, restriction « Référents HTTP »
# GOOGLE_GEOCODING_API_KEY=     → clé serveur : Geocoding API, restriction « Adresses IP » (Scalingo)
# GOOGLE_MAPS_JS=true           → afficher les tuiles Google dans le CRM (sinon OpenStreetMap)

# ─── Base de données ─────────────────────────────────────────────────────────
# Sans DATABASE_URL → SQLite local (data/propscout.db)
# Avec DATABASE_URL → Supabase PostgreSQL (projet « Veliora », voir SUPABASE.md)

# URI PostgreSQL Supabase (Settings → Database → Connection string → URI, pooler 6543)
# IMPORTANT prod Scalingo : port 6543 (transaction), PAS 5432 (session, ~15 conn. max).
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
# Pool app (optionnel) — défaut auto selon port / Scalingo
# DATABASE_POOL_MAX=16
# DATABASE_WEB_RESERVE=10
# DATABASE_POOL_MAX_WAITING=8
# GUNICORN_THREADS=8
# Plafond lignes crawl_logs en Postgres (défaut 5000) — voir SUPABASE.md
# CRAWL_LOG_KEEP=3000
# VELIORA_AUTO_SCHEMA=true

# SQLite local (ignoré si DATABASE_URL est défini)
VELIORA_DB_PATH=data/propscout.db

# Optionnel — clés API Supabase (dashboard → API)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Port HTTP (Scalingo injecte PORT automatiquement)
# PORT=8000

# Crawler navigateur (false sur Scalingo — voir scalingo.json / SCALINGO.md)
# CRAWL_PLAYWRIGHT_ENABLED=true

# Vitesse : balanced (défaut, rapide + fiable) | quality | fast | turbo
# CRAWL_SPEED_PROFILE=balanced
# CITY_CRAWL_MAX_LISTINGS=90
# CITY_DISCOVERY_STOP_LINKS=28

# Clé secrète Flask (sessions futures, CSRF — recommandé en production)
FLASK_SECRET_KEY=changez-moi-en-production-avec-une-chaine-aleatoire-longue

# ─── Stripe (abonnement 500 €/mois par agence) ───────────────────────────────
# Dashboard : https://dashboard.stripe.com/
# Mode test : clés pk_test_… et sk_test_…

# Clé secrète API (serveur uniquement — NE JAMAIS exposer au navigateur)
STRIPE_SECRET_KEY=

# Clé publique (affichée côté client si besoin — Checkout hébergé n'en a pas toujours besoin)
STRIPE_PUBLISHABLE_KEY=

# Secret du webhook (Developers → Webhooks → endpoint → Signing secret whsec_…)
# En local : stripe listen --forward-to localhost:8000/api/billing/webhook
STRIPE_WEBHOOK_SECRET=

# ID du prix récurrent créé dans Stripe (Produit « Veliora agence » 500 €/mois)
# Recommandé en production. Si vide, Veliora crée le prix à la volée (mode test).
STRIPE_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX

# Exiger un abonnement actif pour accéder au CRM (true en production)
# false = accès CRM sans paiement (développement local sans Stripe)
STRIPE_REQUIRE_PAYMENT=true

# Montant affiché / utilisé si STRIPE_PRICE_ID est vide (euros)
SUBSCRIPTION_AMOUNT_EUR=500
SUBSCRIPTION_CURRENCY=eur
SUBSCRIPTION_INTERVAL=month
STRIPE_PRODUCT_NAME=Veliora — Abonnement agence

# ─── Email transactionnel (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Veliora <noreply@votredomaine.fr>
SMTP_USE_TLS=true

# ─── Support, démo, essai ────────────────────────────────────────────────────
SUPPORT_EMAIL=support@votredomaine.fr
SUPPORT_SLA_HOURS=24
DEMO_BOOKING_URL=https://calendly.com/votre-compte/veliora-demo

# Essai Stripe (jours) — 0 = pas d'essai, facturation immédiate
STRIPE_TRIAL_DAYS=0
TRIAL_DAYS=0

# ─── Légal (pages /legal) ────────────────────────────────────────────────────
LEGAL_COMPANY_NAME=Veliora SAS
LEGAL_SIRET=
LEGAL_ADDRESS=
LEGAL_HOSTING=OVH — adresse hébergeur
LEGAL_EMAIL=contact@votredomaine.fr
SITE_URL=https://veliora.fr
VAT_RATE=20

# ─── Site & support ─────────────────────────────────────────────────────────
SUPPORT_EMAIL=support@votredomaine.fr
DEMO_BOOKING_URL=https://calendly.com/votre-compte/demo-veliora
SUPPORT_SLA_HOURS=24
SUBSCRIPTION_AMOUNT_EUR=500

# Limite de portails crawlés par agence (0 = illimité)
MAX_SOURCES_PER_AGENCY=25

# Vitesse crawl : quality | balanced | fast | turbo (défaut : quality)
# quality = comportement humain max / anti-bot (recommandé) | balanced | fast | turbo
CRAWL_SPEED_PROFILE=quality
# Enregistrer les prospects avec téléphone + adresse + surface (email optionnel)
SAVE_ACTIONABLE_LEADS=true

# ─── Proxies (rotation d'IP — pour passer DataDome/Cloudflare comme un service pro) ───
# INDISPENSABLE pour crawler de façon fiable LeBonCoin/SeLoger/PAP/BienIci depuis un
# serveur ou une seule connexion (sinon l'IP est bannie : « Accès temporairement restreint »).
# Utilisez des proxies RÉSIDENTIELS ROTATIFS (ex. IPRoyal, BrightData, Oxylabs, Smartproxy).
# Plusieurs proxies = rotation automatique. Format : http://user:pass@host:port
# CRAWL_PROXIES=http://user:pass@gw1.fournisseur.com:8000,http://user:pass@gw2.fournisseur.com:8000
# Ou un seul :
# CRAWL_PROXY=http://user:pass@host:port

# Pool IP public testé + rotation auto sur TOUS les crawls (défaut true). Désactiver : false
CRAWL_AUTO_FREE_PROXIES=true

# Réseaux agences + petites annonces (La Forêt, ORPI, Entre Particuliers, etc.) dans la veille
# CRAWL_INCLUDE_CATALOG_IN_AUTO=true
# Sites perso ajoutés manuellement dans la veille
# CRAWL_INCLUDE_CUSTOM_IN_AUTO=true

# Mode automatique (pas de Chrome visible ni de test d'URL avant crawl)
CRAWL_SKIP_CITY_PROBE=true
CRAWL_HEADED_FALLBACK=false
DOMAIN_WARMUP=false
CRAWL_PROXY_ROTATE_EACH_CRAWL=true
# Nouvelle IP dès blocage anti-bot / Cloudflare (avec CRAWL_PROXIES)
CRAWL_PROXY_ROTATE_ON_BLOCK=true

# Chrome visible (1) — déconseillé en automatique
CRAWL_HEADFUL=0

# Configurer les proxies : python scripts/configure_proxy_rotation.py --file proxies.txt --test --write-env

# ─── Portails anti-bot (LeBonCoin, SeLoger, PAP, Logic-Immo, BienIci) ───
# Ces portails (DataDome/Cloudflare) exigent DEUX conditions réunies :
#   1) un VRAI navigateur  → CRAWL_PLAYWRIGHT_ENABLED=true (+ Chrome installé sur l'hôte ;
#      Scalingo ne fournit pas Chrome → choisir un hôte qui l'autorise, cf. ORACLE_CLOUD.md) ;
#   2) des proxies RÉSIDENTIELS rotatifs (CRAWL_PROXIES) — le pool public gratuit ne
#      passe PAS DataDome. La rotation IP seule ne suffit jamais sans navigateur.
# Sans navigateur, ces portails sont automatiquement écartés (sinon « 0 annonce » silencieux).
# Forcer l'activation (si vous savez ce que vous faites) :
# CRAWL_ANTIBOT_PORTALS_ENABLED=1
# Pré-résoudre les défis une fois dans un Chrome visible (cookies réutilisés ensuite) :
# AUTO_WARMUP_ANTIBOT=1

# ─── Assistant IA — choisir UN fournisseur ────────────────────────────────────
#
# Option 1 — Groq (RECOMMANDÉ en prod : gratuit, 24/7, ultra rapide)
#   Inscription : https://console.groq.com  →  API Keys  →  Create
#   Puis :
# AI_PROVIDER=groq
# AI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# AI_MODEL=llama-3.3-70b-versatile          # ou llama-3.1-8b-instant pour ultra-rapide
#
# Option 2 — Ollama (local en dev, ou auto-hébergé en prod)
#   En local : `ollama serve` → laisser AI_PROVIDER vide (défaut)
#   En prod auto-hébergé : voir ORACLE_CLOUD.md ou OLLAMA_DEPLOY.md
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434     # en prod : https://ollama.votre-domaine.fr
# OLLAMA_API_KEY=                            # clé Bearer du reverse-proxy (vide en local)
# OLLAMA_MODEL=qwen2.5:7b-instruct
# OLLAMA_FALLBACK_MODEL=llama3.2:3b
#
# Option 3 — Autres APIs compatibles OpenAI (Mistral, OpenAI, OpenRouter, Together)
# AI_PROVIDER=mistral                       # ou openai, openrouter, together
# AI_API_KEY=...
# AI_MODEL=mistral-small-latest             # défaut spécifique à chaque provider sinon
# AI_BASE_URL=                              # override URL (utile pour proxies privés)
#
# ─── Paramètres communs (tous fournisseurs) ──────────────────────────────────
# OLLAMA_NUM_PREDICT=900                    # max_tokens en sortie
# OLLAMA_TEMPERATURE=0.4
# OLLAMA_CONTEXT_TOKENS=8192                # taille du contexte (Ollama uniquement)
# OLLAMA_STREAM_TIMEOUT=180                 # secondes
# AI_MAX_HISTORY=16
# AI_RECENT_ACTIVITY=25
# AI_TOP_LEADS=15
# AI_TOP_CLIENTS=15
