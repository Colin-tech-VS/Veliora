# Scalingo crawle LUI-MÊME SeLoger / LeBonCoin / PAP / Bien'ici (DataDome).
# = pas besoin de worker PC. Nécessite un abonnement Decodo (proxies résidentiels)
# et un dyno L (Chromium consomme de la RAM).
#
# Appliquer (CLI Scalingo) :
#   scalingo --app VOTRE_APP env-set $(grep -v '^#' scripts/scalingo-env-antibot.env | xargs)
# ou coller ces variables dans Dashboard → Environment.

# 1) Navigateur réel + portails anti-bot activés
CRAWL_PLAYWRIGHT_ENABLED=true
CRAWL_ANTIBOT_PORTALS_ENABLED=1

# 2) « new headless » : empreinte quasi-visible, passe DataDome sans écran.
#    Si DataDome bloque encore, passer à l'écran virtuel : CRAWL_XVFB=1
#    (le paquet apt `xvfb` est déjà dans l'Aptfile).
#    En cas de souci de lancement du navigateur : CRAWL_HEADLESS_MODE=old (repli).
CRAWL_HEADLESS_MODE=new
CRAWL_XVFB=false
AUTO_WARMUP_ANTIBOT=false

# 3) OBLIGATOIRE — proxies résidentiels Decodo (sinon DataDome bloque l'IP Scalingo).
#    France rotatif : fr.decodo.com:40000. Remplacez par VOS identifiants.
CRAWL_PROXIES=http://spXXXXXXXX:MOT_DE_PASSE@fr.decodo.com:40000
CRAWL_PROXY_ROTATE_EACH_CRAWL=true
CRAWL_PROXY_ROTATE_ON_BLOCK=true
# Les proxies gratuits ne passent pas DataDome — on s'appuie sur Decodo.
CRAWL_AUTO_FREE_PROXIES=false

# 4) Veille automatique sur Scalingo (pas de worker PC).
CRAWL_AUTO_START=true
# DataDome est lent : laissez de la marge entre les passages pour le quota Decodo.
CRAWL_BACKGROUND_INTERVAL_SEC=600
CRAWL_SKIP_STREAMESTATE=true
