# Veliora sur OVH VPS — copier vers /opt/veliora/.env puis renseigner les secrets.
# Recuperer les valeurs depuis Scalingo : scalingo --app veliora env

APP_PUBLIC_URL=https://veliora.votredomaine.fr
FLASK_SECRET_KEY=GENERER_UNE_CLE_ALEATOIRE_LONGUE
PORT=8000

# Supabase (meme DATABASE_URL que Scalingo, pooler port 6543)
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
VELIORA_AUTO_SCHEMA=true

# Stripe (copier depuis Scalingo)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_REQUIRE_PAYMENT=true
STRIPE_TRIAL_DAYS=0

# SMTP (copier depuis Scalingo)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Decodo France rotating — fr.decodo.com:40000
CRAWL_PROXIES=http://spXXXX:PASSWORD@fr.decodo.com:40000
CRAWL_AUTO_FREE_PROXIES=false
CRAWL_PROXY_ROTATE_EACH_CRAWL=true
CRAWL_PROXY_ROTATE_ON_BLOCK=true

# Site + veille tout-en-un sur le VPS
CRAWL_AUTO_START=true
CRAWL_PLAYWRIGHT_ENABLED=true
CRAWL_ANTIBOT_PORTALS_ENABLED=true
CRAWL_SKIP_STREAMESTATE=true
STREAMESTATE_INCLUDE_IN_VEILLE=false
CRAWL_SPEED_PROFILE=quality
CRAWL_BACKGROUND_INTERVAL_SEC=300
CRAWL_INCLUDE_CATALOG_IN_AUTO=true
CRAWL_INCLUDE_CUSTOM_IN_AUTO=true
CRAWL_LEAD_REFRESH_ENABLED=true

SAVE_ACTIONABLE_LEADS=true
SAVE_MINIMAL_LEADS=false
SAVE_CRAWL_SNAPSHOT=false
ADDRESS_MATCH_DURING_CRAWL=true
DVF_PARALLEL_WORKERS=2
ADDRESS_MATCH_WORKERS=2
CITY_CRAWL_MAX_LISTINGS=90
MAX_LISTING_LINKS=150
