# Variables non secrètes — profil Scalingo « gratuit + rapide + données sûres ».
# Appliquer (PowerShell) :
#   Get-Content scripts/scalingo-env-apply.env | Where-Object { $_ -and $_ -notmatch '^\s*#' } | ForEach-Object { scalingo --app veliora env-set $_ }
# Bash :
#   grep -v '^\s*#' scripts/scalingo-env-apply.env | xargs -I{} scalingo --app veliora env-set {}

APP_PUBLIC_URL=https://veliora.osc-fr1.scalingo.io
VELIORA_AUTO_SCHEMA=true
VELIORA_DB_PATH=/var/lib/data/propscout.db
STRIPE_REQUIRE_PAYMENT=true
STRIPE_TRIAL_DAYS=0
SUBSCRIPTION_AMOUNT_EUR=500
SUBSCRIPTION_CURRENCY=eur
SUBSCRIPTION_INTERVAL=month
STRIPE_PRODUCT_NAME=Veliora — Abonnement agence
SMTP_PORT=587
SMTP_USE_TLS=true
SUPPORT_SLA_HOURS=24
LEGAL_COMPANY_NAME=Veliora
VAT_RATE=20
MAX_SOURCES_PER_AGENCY=30

# Qualité : uniquement fiches exploitables (tél/email + adresse + prix/surface cohérents)
SAVE_ACTIONABLE_LEADS=true
SAVE_MINIMAL_LEADS=false
SAVE_CRAWL_SNAPSHOT=false

# Crawl HTTP gratuit (pas de Chrome sur Scalingo)
CRAWL_PLAYWRIGHT_ENABLED=false
AUTO_WARMUP_ANTIBOT=false
DOMAIN_WARMUP=false
CRAWL_SKIP_CITY_PROBE=true
CRAWL_HEADED_FALLBACK=false
CRAWL_HEADFUL=false
CRAWL_ANTIBOT_PORTALS_ENABLED=false

# Vitesse (la validation prix/surface/INSEE reste active quel que soit le profil)
CRAWL_SPEED_PROFILE=fast
CITY_CRAWL_MAX_LISTINGS=90
CITY_DISCOVERY_STOP_LINKS=28
MAX_LISTING_LINKS=150
MAX_SEARCH_PAGES=14
MAX_SITE_DISCOVERY_PAGES=22
CRAWL_HTTP_TIMEOUT_SEC=12
ANTIBOT_CHALLENGE_WAIT_MS=10000

# Rotation IP gratuite (rate-limit) — pas DataDome
CRAWL_PROXIES=
CRAWL_PROXY_ROTATE_EACH_CRAWL=true
CRAWL_PROXY_ROTATE_ON_BLOCK=true
CRAWL_AUTO_FREE_PROXIES=true

# Couverture portails accessibles sans navigateur
CRAWL_INCLUDE_CATALOG_IN_AUTO=true
CRAWL_INCLUDE_CUSTOM_IN_AUTO=true
SITE_WIDE_CRAWL_ENABLED=true
CRAWL_AI_DISCOVERY=auto

# Enrichissement parallèle (1 worker = adapté dyno M)
ADDRESS_MATCH_DURING_CRAWL=true
ADDRESS_MATCH_WORKERS=1
ADDRESS_MATCH_DRAIN_TIMEOUT_SEC=120
DVF_PARALLEL_WORKERS=1
DVF_QUEUE_DRAIN_TIMEOUT_SEC=90

# Cohérence surface
SURFACE_MIN_SALE_M2=5
SURFACE_MAX_SALE_M2=500
SURFACE_MIN_RENT_M2=8
SURFACE_MAX_RENT_M2=300

# Veille auto
CRAWL_AUTO_START=true
CRAWL_BACKGROUND_INTERVAL_SEC=300
CRAWL_LEAD_REFRESH_ENABLED=true
CRAWL_LEAD_REFRESH_INTERVAL_SEC=3600
CRAWL_LEAD_REFRESH_STALE_HOURS=24
CRAWL_LEAD_REFRESH_MAX_PER_RUN=20
CRAWL_VEILLE_SOURCE_MAX_SEC=480
CRAWL_VEILLE_SEC_PER_EXISTING=3
CRAWL_VEILLE_SOURCE_MAX_CAP_SEC=2400
CRAWL_VEILLE_DISCOVERY_MAX_LISTINGS=90

# StreamEstate : pas de veille auto (économie crédits) — activer la clé à part si besoin
STREAMESTATE_INCLUDE_IN_VEILLE=false
STREAMESTATE_PARTICULIER_ONLY=true
STREAMESTATE_WITH_COHERENT_PRICE=true
STREAMESTATE_TRANSACTION_SALE=true
STREAMESTATE_MAX_LISTINGS=60
STREAMESTATE_MAX_PAGES=2
STREAMESTATE_VEILLE_MAX_LISTINGS=10
STREAMESTATE_VEILLE_MAX_PAGES=1
