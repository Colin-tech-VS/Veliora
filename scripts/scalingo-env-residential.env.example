# Scalingo — CRM uniquement (veille sur worker Decodo local).
# Copier vers scalingo-env-residential.env — CRAWL_PROXIES optionnel ici (surtout sur le worker).
# Appliquer : .\scripts\apply-decodo-crawl.ps1 -Target scalingo

CRAWL_PROXIES=
CRAWL_AUTO_FREE_PROXIES=false
CRAWL_PROXY_ROTATE_EACH_CRAWL=true
CRAWL_PROXY_ROTATE_ON_BLOCK=true

# Veille = worker PC (Playwright + Decodo), pas Scalingo
CRAWL_AUTO_START=false
CRAWL_PLAYWRIGHT_ENABLED=false
CRAWL_ANTIBOT_PORTALS_ENABLED=false

CRAWL_SKIP_STREAMESTATE=true
STREAMESTATE_INCLUDE_IN_VEILLE=false

CRAWL_SPEED_PROFILE=balanced
SAVE_ACTIONABLE_LEADS=true
SAVE_MINIMAL_LEADS=false
SAVE_CRAWL_SNAPSHOT=false
ADDRESS_MATCH_DURING_CRAWL=true
CRAWL_INCLUDE_CATALOG_IN_AUTO=true
CRAWL_INCLUDE_CUSTOM_IN_AUTO=true
